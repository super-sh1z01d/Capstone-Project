# Optional. When unset, the app runs in deterministic Demo Fallback mode.
# GEMINI_API_KEY is preferred; GOOGLE_API_KEY is also supported for compatibility.
GEMINI_API_KEY=
GOOGLE_API_KEY=

# Optional Gemini model for AI synthesis.
GEMINI_MODEL=gemini-2.5-flash

# Optional runtime selector: auto, fallback, adk.
AGENT_RUNTIME=auto
